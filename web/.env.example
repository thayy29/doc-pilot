# ─────────────────────────────────────────────────────────────────────────
# 📦 DocPilot Environment Configuration
# ─────────────────────────────────────────────────────────────────────────
# Complete setup guide: https://github.com/thayy29/doc-pilot#setup

# ─────────────────────────────────────────────────────────────────────────
# 🗄️  Database (PostgreSQL + pgvector)
# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string with pgvector support
# Local: postgresql://user:password@localhost:5432/docpilot?schema=public
# Supabase: postgresql://postgres.[project-id]:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/docpilot?schema=public"

# ─────────────────────────────────────────────────────────────────────────
# 🔐 Auth.js / NextAuth Configuration
# ─────────────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: gere com: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"

# ─────────────────────────────────────────────────────────────────────────
# 🔑 OAuth Providers (GitHub & Google)
# ─────────────────────────────────────────────────────────────────────────
# GitHub: https://github.com/settings/developers → New OAuth App
GITHUB_ID=""
GITHUB_SECRET=""

# Google: https://console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_ID=""
GOOGLE_SECRET=""

# ─────────────────────────────────────────────────────────────────────────
# 🧠 OpenAI (Embeddings)
# ─────────────────────────────────────────────────────────────────────────
# API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Modelo de embeddings (1536d ou 3072d)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="1536"

# ─────────────────────────────────────────────────────────────────────────
# 🤖 Anthropic / Claude (Chat RAG Streaming)
# ─────────────────────────────────────────────────────────────────────────
# API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Modelo Claude a usar (streaming)
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Máximo de tokens na resposta
ANTHROPIC_MAX_TOKENS="2048"

# ─────────────────────────────────────────────────────────────────────────
# 🔴 Redis (BullMQ Worker Queue)
# ─────────────────────────────────────────────────────────────────────────
# Local Redis: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────────────────────────────────
# 🏢 Application Settings
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────
# 📊 Observability
# ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
ENABLE_COST_TRACKING="true"
